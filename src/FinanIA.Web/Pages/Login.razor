@page "/login"
@using System.ComponentModel.DataAnnotations
@using FinanIA.Web.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Entrar</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Entrar</MudText>

    <MudForm @ref="_form" Model="@_model">
        <MudTextField T="string" Label="E-mail" @bind-Value="_model.Email" InputType="InputType.Email"
                      Validation="@(new EmailAddressAttribute() { ErrorMessage = "Formato de e-mail inválido." })" Required="true"
                      RequiredError="E-mail é obrigatório." Class="mb-4" />

        <MudTextField T="string" Label="Senha" @bind-Value="_model.Password" InputType="InputType.Password"
                      Required="true" RequiredError="Senha é obrigatória." Class="mb-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" OnClick="HandleSubmit"
                   FullWidth="true">
            @if (_isLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Aguarde...</span>
            }
            else
            {
                <span>Entrar</span>
            }
        </MudButton>
    </MudForm>

    <MudText Class="mt-4">
        Não tem conta? <MudLink Href="/register">Criar conta</MudLink>
    </MudText>
</MudContainer>

@code {
    private MudForm _form = default!;
    private readonly LoginModel _model = new();
    private bool _isLoading;

    private async Task HandleSubmit()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        _isLoading = true;

        var currentPath = new Uri(NavigationManager.Uri).PathAndQuery;
        var returnUrl = currentPath == "/login" ? "/" : currentPath;

        var (success, error) = await AuthService.LoginAsync(_model.Email, _model.Password, returnUrl);

        if (!success)
        {
            Snackbar.Add(error ?? "E-mail ou senha incorretos.", Severity.Error);
            _isLoading = false;
        }
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "E-mail é obrigatório.")]
        [EmailAddress(ErrorMessage = "Formato de e-mail inválido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Senha é obrigatória.")]
        public string Password { get; set; } = string.Empty;
    }
}
