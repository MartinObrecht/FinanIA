@page "/chat"
@using FinanIA.Web.Services
@inject AssistantService AssistantService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Assistente IA</PageTitle>

<MudText Typo="Typo.h4" Class="mb-3">Assistente Financeiro</MudText>

<!-- Chat Thread -->
<MudPaper Elevation="2" Class="pa-3 mb-3 overflow-y-auto" Style="min-height:300px;max-height:500px;" id="chat-thread">
    @if (_history.Count == 0)
    {
        <MudText Color="Color.Secondary">Olá! Pergunte-me sobre suas finanças.</MudText>
    }
    else
    {
        @foreach (var turn in _history)
        {
            @if (turn.Role == "user")
            {
                <div class="d-flex justify-end mb-2">
                    <MudPaper Elevation="1" Class="pa-2 rounded mud-theme-primary" Style="max-width:75%;word-break:break-word;">
                        <MudText>@turn.Content</MudText>
                    </MudPaper>
                </div>
            }
            else
            {
                <div class="d-flex justify-start mb-2">
                    <div style="max-width:75%;">
                        <MudPaper Elevation="1" Class="pa-2 rounded" Style="white-space:pre-wrap;word-break:break-word;">
                            <MudText>@turn.Content</MudText>
                        </MudPaper>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Esta resposta não substitui aconselhamento financeiro profissional.
                        </MudText>
                    </div>
                </div>
            }
        }
        @if (_isLoading)
        {
            <div class="d-flex justify-start mb-2">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
            </div>
        }
    }
</MudPaper>

<!-- Input Area -->
<div class="d-flex gap-2 align-center">
    <MudTextField T="string"
                  @bind-Value="_message"
                  Placeholder="Escreva sua pergunta..."
                  MaxLength="2000"
                  Variant="Variant.Outlined"
                  Disabled="@_isLoading"
                  OnKeyDown="HandleKeyDown"
                  Class="flex-grow-1" />
    <MudIconButton Icon="@Icons.Material.Filled.Send"
                   Color="Color.Primary"
                   OnClick="HandleSend"
                   Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_message))" />
</div>
<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@_message.Length / 2000 caracteres</MudText>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
}

@code {
    private string _message = string.Empty;
    private bool _isLoading;
    private string? _errorMessage;
    private readonly List<ConversationTurn> _history = [];

    private async Task HandleSend()
    {
        var userMessage = _message.Trim();
        if (string.IsNullOrWhiteSpace(userMessage) || _isLoading)
            return;

        _errorMessage = null;
        _message = string.Empty;
        _history.Add(new ConversationTurn("user", userMessage));
        _isLoading = true;

        try
        {
            var previousMessages = _history
                .Take(_history.Count - 1)
                .ToList()
                .AsReadOnly();

            var (result, error) = await AssistantService.AskAsync(userMessage, previousMessages);

            if (error is not null || result is null)
            {
                _errorMessage = error ?? "Resposta inválida do assistente.";
                _history.RemoveAt(_history.Count - 1);
            }
            else
            {
                _history.Add(new ConversationTurn("assistant", result.Reply));
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await HandleSend();
    }
}
