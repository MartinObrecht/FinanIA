@page "/register"
@using System.ComponentModel.DataAnnotations
@using FinanIA.Web.Services
@inject AuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Criar Conta</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Criar Conta</MudText>

    <MudForm @ref="_form" Model="@_model">
        <MudTextField T="string" Label="E-mail" @bind-Value="_model.Email" InputType="InputType.Email"
                      Validation="@(new EmailAddressAttribute() { ErrorMessage = "Formato de e-mail inválido." })" Required="true"
                      RequiredError="E-mail é obrigatório." Class="mb-4" />

        <MudTextField T="string" Label="Senha" @bind-Value="_model.Password" InputType="InputType.Password"
                      Required="true" RequiredError="Senha é obrigatória." Class="mb-4" />

        <MudTextField T="string" Label="Confirmar Senha" @bind-Value="_model.ConfirmPassword"
                      InputType="InputType.Password" Required="true" RequiredError="Confirmação de senha é obrigatória."
                      Class="mb-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" OnClick="HandleSubmit"
                   FullWidth="true">
            @if (_isLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Aguarde...</span>
            }
            else
            {
                <span>Criar Conta</span>
            }
        </MudButton>
    </MudForm>
</MudContainer>

@code {
    private MudForm _form = default!;
    private readonly RegisterModel _model = new();
    private bool _isLoading;

    private async Task HandleSubmit()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        _isLoading = true;

        var (success, error) = await AuthService.RegisterAsync(_model.Email, _model.Password);

        if (success)
        {
            Snackbar.Add("Conta criada com sucesso!", Severity.Success);
        }
        else
        {
            Snackbar.Add(error ?? "Falha no registro.", Severity.Error);
            _isLoading = false;
        }
    }

    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "E-mail é obrigatório.")]
        [EmailAddress(ErrorMessage = "Formato de e-mail inválido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Senha é obrigatória.")]
        [MinLength(6, ErrorMessage = "A senha deve ter no mínimo 6 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirmação de senha é obrigatória.")]
        [Compare(nameof(Password), ErrorMessage = "As senhas não coincidem.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
