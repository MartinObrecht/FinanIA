@page "/transactions"
@using FinanIA.Web.Services
@inject TransactionService TransactionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Transações</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Transações</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenCreateDialog" Class="mb-4">
    Nova Transação
</MudButton>

@if (_isLoadingList)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_transactions.Count == 0)
{
    <MudText Color="Color.Secondary">Nenhuma transação encontrada.</MudText>
}
else
{
    <MudTable Items="_transactions" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
        <HeaderContent>
            <MudTh>Descrição</MudTh>
            <MudTh>Valor</MudTh>
            <MudTh>Data</MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Descrição">
                <span style="display:block;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                      title="@context.Description">
                    @context.Description
                </span>
            </MudTd>
            <MudTd DataLabel="Valor">R$ @context.Amount.ToString("N2")</MudTd>
            <MudTd DataLabel="Data">@context.Date.ToString("dd/MM/yyyy")</MudTd>
            <MudTd DataLabel="Tipo">
                <MudChip T="string" Color="@(context.Type == "Income" ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.Type == "Income" ? "Receita" : "Despesa")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="() => ConfirmDeleteAsync(context.Id)" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<TransactionResponse> _transactions = [];
    private bool _isLoadingList = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactionsAsync();
    }

    private async Task LoadTransactionsAsync()
    {
        _isLoadingList = true;
        _transactions = (await TransactionService.GetTransactionsAsync()).ToList();
        _isLoadingList = false;
    }

    private async Task OpenCreateDialog()
    {
        var model = new TransactionFormModel { Date = DateOnly.FromDateTime(DateTime.Today) };
        var result = await OpenFormDialog(model);
        if (result is null) return;

        var (_, error) = await TransactionService.CreateTransactionAsync(
            result.Description, result.Amount, result.Date!.Value, result.Type);

        if (error is not null)
            Snackbar.Add(error, Severity.Error);
        else
        {
            Snackbar.Add("Transação registrada com sucesso!", Severity.Success);
            await LoadTransactionsAsync();
        }
    }

    private async Task OpenEditDialog(TransactionResponse tx)
    {
        var model = new TransactionFormModel
        {
            Id = tx.Id,
            Description = tx.Description,
            Amount = tx.Amount,
            Date = tx.Date,
            Type = tx.Type
        };

        var result = await OpenFormDialog(model);
        if (result is null) return;

        var (_, error) = await TransactionService.UpdateTransactionAsync(
            tx.Id, result.Description, result.Amount, result.Date!.Value, result.Type);

        if (error is not null)
            Snackbar.Add(error, Severity.Error);
        else
        {
            Snackbar.Add("Transação atualizada com sucesso!", Severity.Success);
            await LoadTransactionsAsync();
        }
    }

    private async Task<TransactionFormModel?> OpenFormDialog(TransactionFormModel initialModel)
    {
        var parameters = new DialogParameters<TransactionFormDialog>
        {
            { x => x.InitialModel, initialModel }
        };
        var dialog = await DialogService.ShowAsync<TransactionFormDialog>(string.Empty, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return null;
        return result.Data as TransactionFormModel;
    }

    private async Task ConfirmDeleteAsync(Guid id)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirmar exclusão",
            "Deseja excluir permanentemente esta transação?",
            yesText: "Excluir",
            cancelText: "Cancelar");

        if (confirmed != true) return;

        var (success, error) = await TransactionService.DeleteTransactionAsync(id);
        if (!success)
            Snackbar.Add(error ?? "Falha ao excluir transação.", Severity.Error);
        else
        {
            Snackbar.Add("Transação excluída com sucesso!", Severity.Success);
            await LoadTransactionsAsync();
        }
    }
}
