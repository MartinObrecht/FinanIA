@page "/balance"
@using FinanIA.Web.Services
@inject TransactionService TransactionService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Saldo</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Saldo Financeiro</MudText>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_balance is null)
{
    <MudAlert Severity="Severity.Warning">Não foi possível carregar o saldo.</MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Total de Receitas</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="text-center">
                    <MudText Typo="Typo.h5" Color="Color.Success">R$ @_balance.TotalIncome.ToString("N2")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Total de Despesas</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="text-center">
                    <MudText Typo="Typo.h5" Color="Color.Error">R$ @_balance.TotalExpense.ToString("N2")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Saldo Atual</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="text-center">
                    <MudText Typo="Typo.h5">R$ @_balance.Balance.ToString("N2")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private BalanceResponse? _balance;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _balance = await TransactionService.GetBalanceAsync();
        _isLoading = false;
    }
}
